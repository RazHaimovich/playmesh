{
  "name": "@playmesh/server",
  "version": "0.1.0",
  "description": "PlayMesh multiplayer server framework — Socket.IO, Redis and BullMQ infrastructure for multiplayer worlds.",
  "keywords": [
    "multiplayer",
    "socket.io",
    "realtime",
    "game-server",
    "redis",
    "websocket"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "socket.io-client": "^4.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
