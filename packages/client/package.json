{
  "name": "@playmesh/client",
  "version": "0.1.4",
  "description": "PlayMesh client SDK — connect games and applications to PlayMesh servers.",
  "keywords": [
    "multiplayer",
    "socket.io",
    "realtime",
    "game-client",
    "websocket"
  ],
  "homepage": "https://playmesh.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/RazHaimovich/playmesh",
    "directory": "packages/client"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
